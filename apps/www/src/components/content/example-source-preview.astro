---
import { getExampleSource } from "@/lib/source";
import type { UiLibrary } from "@/store/atoms/framework";
import CodeWrapper from "./code-wrapper/index.astro";

export interface Props {
  uiLibrary: UiLibrary;
  example: string;
}

const { uiLibrary, example } = Astro.props;

const { source, lang } = (await getExampleSource(uiLibrary, example)) || {};
---

<div data-ui-library={uiLibrary}>
  {source ? (
    <CodeWrapper className="mt-0" lang={lang} src={source} collapsible />
  ) : (
    <CodeWrapper src={"Not Found"} />
  )}
</div>
