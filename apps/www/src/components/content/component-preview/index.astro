---
import { getExampleSource } from "@/lib/source";
import { $framework, uiLibraries } from "@/store/atoms/framework";
import ExampleSourcePreview from "../example-source-preview.astro";
import NotFound from "./not-found.astro";
import Preview from "./preview";
import Tabs from "./tabs";

export interface Props {
  name: string;
}
const { name } = Astro.props;

const sources = await Promise.all(
  uiLibraries.map((uiLibrary) => getExampleSource(uiLibrary, name))
);
---

<div class="relative my-4 flex flex-col space-y-2 lg:max-w-[120ch]">
  <Tabs client:visible>
    <Fragment slot="preview">
      {
        uiLibraries.map((uiLibrary, index) => (
          <div
            class="relative flex min-h-[350px] max-w-screen flex-col items-center justify-center rounded-xl border"
            data-ui-library={uiLibrary}
            hidden={$framework.value !== uiLibrary}
          >
            {sources[index] ? (
              <Preview client:visible name={name} hidden={!sources[index]} />
            ) : (
              <NotFound component={name} />
            )}
          </div>
        ))
      }
    </Fragment>
    <Fragment slot="code">
      {
        uiLibraries.map((uiLibrary) => (
          <ExampleSourcePreview uiLibrary={uiLibrary} example={name} />
        ))
      }
    </Fragment>
  </Tabs>
</div>
